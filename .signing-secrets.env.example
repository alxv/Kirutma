# Copy to .signing-secrets.env and fill in (never commit .signing-secrets.env)
# Then run: ./scripts/setup-github-secrets.sh

# --- Mac (Developer ID Application + notarization) ---
# Export .p12 from Keychain Access → My Certificates → Developer ID Application
APPLE_CERTIFICATE_FILE=/path/to/certificate.p12
APPLE_CERTIFICATE_PASSWORD=
KEYCHAIN_PASSWORD=
APPLE_ID=your@email.com
APPLE_PASSWORD=
APPLE_TEAM_ID=

# --- Windows (code signing .pfx) ---
# Skip Windows secrets if you only have Mac cert for now
WINDOWS_CERTIFICATE_FILE=/path/to/certificate.pfx
WINDOWS_CERTIFICATE_PASSWORD=
WINDOWS_CERTIFICATE_THUMBPRINT=
